{
  "expo": {
    "name": "RiderLens",
    "slug": "riderlens",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "riderlens",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.riderlens.app",
      "infoPlist": {
        "NSCameraUsageDescription": "RiderLens uses the camera to record short bike technique clips for coaching feedback.",
        "NSMicrophoneUsageDescription": "RiderLens may record audio with bike technique clips.",
        "NSPhotoLibraryUsageDescription": "RiderLens lets you upload existing bike technique clips for analysis.",
        "NSMotionUsageDescription": "RiderLens uses motion sensors for the level and inclinometer tool.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.riderlens.app",
      "permissions": [
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.BODY_SENSORS",
        "android.permission.ACTIVITY_RECOGNITION",
        "com.google.android.gms.permission.ACTIVITY_RECOGNITION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#bcfa18"
      }
    },
    "plugins": [
      "expo-font",
      "expo-image-picker",
      "expo-video",
      [
        "@sentry/react-native/expo",
        {
          "organization": "antonio-fernandes",
          "project": "riderlens-app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-lockup.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#bbfa17"
        }
      ]
    ],
    "extra": {
      "analysisWorkerUrl": "",
      "eas": {
        "projectId": "0f616ef7-14e0-4d22-aafe-a794ba90946a"
      }
    },
    "owner": "mopiu",
    "icon": "./assets/icon.png"
  }
}
